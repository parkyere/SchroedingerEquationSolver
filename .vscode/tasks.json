{
    "version": "2.0.0",
    "tasks": [
        {
            // Zero-state F5 build: pinned to the linux-clang22 preset so a
            // fresh clone builds WITHOUT touching the CMake Tools preset
            // picker (its "active preset" is per-machine UI state, not a
            // repo file). Configure runs only when the build tree is absent.
            // Linux-only by design -- Windows uses Visual Studio directly.
            "label": "cmake-build-app",
            "type": "shell",
            "command": "[ -f out/build/linux-clang22/CMakeCache.txt ] || cmake --preset linux-clang22; cmake --build --preset linux-clang22 --target sesolver_app",
            "options": { "cwd": "${workspaceFolder}" },
            "problemMatcher": ["$gcc"],
            "detail": "configure-if-needed + build sesolver_app (linux-clang22)"
        },
        {
            // Ctrl+Shift+B: everything (tests + vkcheck + app), same pin.
            "label": "cmake-build-all",
            "type": "shell",
            "command": "[ -f out/build/linux-clang22/CMakeCache.txt ] || cmake --preset linux-clang22; cmake --build --preset linux-clang22",
            "options": { "cwd": "${workspaceFolder}" },
            "group": { "kind": "build", "isDefault": true },
            "problemMatcher": ["$gcc"],
            "detail": "configure-if-needed + build everything (linux-clang22)"
        }
    ]
}
